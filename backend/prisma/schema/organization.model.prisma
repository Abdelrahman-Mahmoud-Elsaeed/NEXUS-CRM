model Organization {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  billingPlan String   @default("free") @map("billing_plan")
  createdAt   DateTime @default(now()) @map("created_at")
  avatar      String?

  members        OrganizationUser[]
  contacts       Contact[]
  deals          Deal[]
  tags           Tag[]
  pipelines      Pipeline[]
  pipelineStages PipelineStage[]
  tasks          Task[]
  automations    Automation[]
  invitations    Invitation[]
  companies      Company[]

  @@map("organizations")
}