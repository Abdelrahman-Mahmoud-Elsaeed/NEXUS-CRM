model Task {
  id          String       @id @default(uuid()) @db.Uuid
  title       String
  description String?      @db.Text
  dueDate     DateTime?    @map("due_date")
  status      TaskStatus   @default(Pending)
  priority    TaskPriority @default(Medium)

  contactId      String       @db.Uuid @map("contact_id")
  contact        Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  organizationId String       @db.Uuid @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  assignedToId   String?      @db.Uuid @map("assigned_to_id")
  assignee       User?        @relation("TaskAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdById    String?      @db.Uuid @map("created_by_id")
  creator        User?        @relation("TaskCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")

  @@map("tasks")
}