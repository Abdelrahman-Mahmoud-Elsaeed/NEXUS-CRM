model Deal {
  id                String       @id @default(uuid()) @db.Uuid
  name              String
  value             Decimal?     @db.Decimal(12, 2)
  currency          String       @default("USD")
  status            DealStatus   @default(Open)
  
  expectedCloseDate DateTime?    @map("expected_close_date")
  actualCloseDate   DateTime?    @map("actual_close_date")
  notes             String?      @db.Text

  organizationId    String       @db.Uuid @map("organization_id")
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  companyId         String?      @db.Uuid @map("company_id")
  company           Company?     @relation(fields: [companyId], references: [id], onDelete: SetNull)

  primaryContactId  String?      @db.Uuid @map("primary_contact_id")
  primaryContact    Contact?     @relation(fields: [primaryContactId], references: [id], onDelete: SetNull)

  pipelineId        String?      @db.Uuid @map("pipeline_id")
  pipeline          Pipeline?    @relation(fields: [pipelineId], references: [id], onDelete: SetNull)

  stageId           String?      @db.Uuid @map("stage_id")
  stage             PipelineStage? @relation(fields: [stageId], references: [id], onDelete: SetNull)

  assignedToId      String?      @db.Uuid @map("assigned_to_id")
  assignee          User?        @relation("DealAssignee", fields: [assignedToId], references: [id], onDelete: SetNull)

  createdById       String?      @db.Uuid @map("created_by_id")
  creator           User?        @relation("DealCreator", fields: [createdById], references: [id], onDelete: SetNull)

  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")

  @@map("deals")
}